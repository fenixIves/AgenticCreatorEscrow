# Copy to `.env` for local live-demo runs. Never commit real private keys.

# Sepolia / CAW DEV chain target.
SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
ETHERSCAN_API_KEY=

# Deployed JobEscrow and demo participants.
JOB_ESCROW=
SRC=0x0db0aa2bed1e0710a51d44a6f87ad62e28bbfbd7
PLATFORM=
CREATOR=
SUPPLIER=
PACT_ID=

# Set these when rerunning a fresh demo without redeploying JobEscrow.
# ACE_RUN_ID must be new for each live run so CAW request-id idempotency does not reuse old tx records.
# ACE_JOB_ID is the JobEscrow job id created by the latest createJob call.
ACE_RUN_ID=001
ACE_JOB_ID=1

# Optional creator wallets for cast-based proposal/delivery templates.
CREATOR_A_PRIVATE_KEY=
CREATOR_B_PRIVATE_KEY=

# Optional transaction hashes for the browser demo receipts.
CAW_BASIC_TRANSFER_TX_HASH=
CAW_WETH_DEPOSIT_TX_HASH=
JOBESCROW_CREATE_TX_HASH=
JOBESCROW_PROPOSAL_A_TX_HASH=
JOBESCROW_PROPOSAL_B_TX_HASH=
JOBESCROW_ASSIGN_TX_HASH=
JOBESCROW_SUPPLIER_TX_HASH=
JOBESCROW_DELIVERY_TX_HASH=
JOBESCROW_SETTLE_TX_HASH=

# Optional local frontend runner.
ACE_RUNNER_PORT=4180
ACE_POLL_ATTEMPTS=15
ACE_POLL_INTERVAL_MS=2500
